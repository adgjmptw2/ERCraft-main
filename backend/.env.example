DATABASE_URL=mysql://user:password@localhost:3306/ercraft
TEST_DATABASE_URL=mysql://user:password@localhost:3306/ercraft_test
PORT=3001
CORS_ORIGIN=http://localhost:5173
BSER_API_KEY=
# 비워두면(0) BSER Season 테이블 isCurrent 행 사용 (API row "Season20" = 플레이어 S11)
BSER_SEASON_ID=0
# fixed-v1 | fixed-v2 | experimental-local | legacy
# 기본값 fixed-v1: 고정 통계 기준 + legacy role/combat. local DB live 기준선은 experimental-local에서만 사용.
CHARACTER_GRADE_BENCHMARK_SOURCE=fixed-v1
# Autonomous collector defaults. Disabled unless the CLI is explicitly run.
COLLECTOR_ENABLED=false
COLLECTOR_MAX_RPS=1
COLLECTOR_DAILY_BUDGET=200000
COLLECTOR_INTERACTIVE_RESERVE_PERCENT=30
COLLECTOR_USER_PAGE_LIMIT=1
COLLECTOR_MAX_DISCOVERY_DEPTH=20
COLLECTOR_MAX_RETRIES=5
COLLECTOR_LEASE_SECONDS=120
COLLECTOR_GAME_BUDGET_PERCENT=50
COLLECTOR_IDENTITY_BUDGET_PERCENT=25
COLLECTOR_USER_BUDGET_PERCENT=20
COLLECTOR_MAINTENANCE_BUDGET_PERCENT=5
COLLECTOR_IDENTITY_ENABLED=true
COLLECTOR_IDENTITY_QUICK_PAGES=1
COLLECTOR_IDENTITY_NORMAL_PAGES=3
COLLECTOR_IDENTITY_DEEP_PAGES=20
COLLECTOR_IDENTITY_DEEP_ENABLED=true
COLLECTOR_IDENTITY_DEEP_PRIORITY_THRESHOLD=80
COLLECTOR_IDENTITY_MAX_RETRIES=3
COLLECTOR_MAX_WORK_ITERATIONS_MULTIPLIER=20
COLLECTOR_PRIORITY_REFRESH_BATCH_SIZE=500
COLLECTOR_PRIORITY_REFRESH_INTERVAL_MINUTES=60
COLLECTOR_IDENTITY_BACKLOG_SOFT_LIMIT=5000
COLLECTOR_IDENTITY_BACKLOG_SOFT_EXIT=4000
COLLECTOR_IDENTITY_BACKLOG_HARD_LIMIT=15000
COLLECTOR_IDENTITY_BACKLOG_HARD_EXIT=12000
COLLECTOR_GAME_BACKLOG_SOFT_PERCENT=35
COLLECTOR_IDENTITY_BACKLOG_SOFT_PERCENT=40
COLLECTOR_GAME_BACKLOG_HARD_PERCENT=20
COLLECTOR_IDENTITY_BACKLOG_HARD_PERCENT=55
COLLECTOR_IDENTITY_DEFER_NICKNAME_PENDING_LIMIT=12
COLLECTOR_IDENTITY_GROUP_SIZE=25
COLLECTOR_IDENTITY_GROUP_MAX_SOURCE_GAMES=25
COLLECTOR_IDENTITY_RESOLVE_BATCH_SIZE=25
COLLECTOR_IDENTITY_OLD_SOURCE_DEFER_DAYS=180
COLLECTOR_MODE_BALANCED_ENTER_PENDING=5000
COLLECTOR_MODE_BALANCED_EXIT_PENDING=3500
COLLECTOR_MODE_DRAIN_ENTER_PENDING=10000
COLLECTOR_MODE_DRAIN_EXIT_PENDING=7000
COLLECTOR_MODE_EMERGENCY_ENTER_PENDING=20000
COLLECTOR_MODE_EMERGENCY_EXIT_PENDING=14000
COLLECTOR_MODE_GROWTH_DRAIN_RATIO=2
COLLECTOR_MODE_GROWTH_EMERGENCY_RATIO=5
COLLECTOR_MODE_MIN_DURATION_SECONDS=300
COLLECTOR_MODE_STABLE_GROWTH_PERCENT=1
COLLECTOR_MODE_RUN_GROWTH_EMERGENCY_PERCENT=25
COLLECTOR_IDENTITY_QUEUE_HARD_CAP=100000
COLLECTOR_DRAIN_DEEP_MIN_RESOLVED_PER_PAGE=0.25
COLLECTOR_DRAIN_DEEP_MAX_API_PERCENT=20
COLLECTOR_DRAIN_GAME_API_MAX_PERCENT=5
COLLECTOR_DRAIN_USER_API_MAX_PERCENT=5
COLLECTOR_BALANCED_STABILITY_SAFETY_FACTOR=0.90
COLLECTOR_BALANCED_GAME_API_MAX_PERCENT=25
COLLECTOR_BALANCED_USER_API_MAX_PERCENT=15
COLLECTOR_BALANCED_MIN_IDENTITY_PERCENT=55
COLLECTOR_BALANCED_OBSERVATION_MIN_SAMPLES=3
COLLECTOR_BALANCED_EWMA_ALPHA=0.25
COLLECTOR_BALANCED_MAX_CAP_INCREASE_PER_RUN_PERCENT=1
UNKNOWN_AUDIT_COHORT_CUTOFF_ISO=
COLLECTOR_IDENTITY_COMPACTION_BATCH_SIZE=500
# DB 캐시(seasonStatsCache, playerSeasonsCache, matchesCache) 사용 시:
# npx prisma migrate dev && npx prisma generate
