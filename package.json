{
  "name": "ercraft",
  "description": "Eternal Return player stats & match history UI (mock data, TypeScript + Vite + TanStack Query)",
  "keywords": [
    "eternal-return",
    "react",
    "typescript",
    "vite",
    "tanstack-query",
    "tailwindcss"
  ],
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "assets:import-fankit": "node scripts/import-fankit-assets.mjs",
    "assets:import-cobalt-infusion-official-icons": "node scripts/import-cobalt-infusion-official-icons.mjs",
    "assets:sync-cobalt-infusion-manifest": "node scripts/sync-cobalt-infusion-manifest.mjs",
    "assets:sync-cobalt-infusion-product-groups": "node scripts/sync-cobalt-infusion-product-group-assets.mjs",
    "assets:refresh-cobalt-infusions": "node scripts/sync-cobalt-infusion-manifest.mjs && node scripts/import-fankit-assets.mjs && node scripts/import-cobalt-infusion-official-icons.mjs && node scripts/generate-cobalt-infusion-catalog.mjs && node scripts/sync-cobalt-infusion-product-group-assets.mjs",
    "assets:import-fankit:characters": "node scripts/import-fankit-characters.mjs",
    "assets:import-fankit:all": "node scripts/import-fankit-assets.mjs && node scripts/import-fankit-characters.mjs",
    "assets:reoptimize-icons": "node scripts/reoptimize-icon-assets.mjs",
    "assets:generate-character-maps": "node scripts/generate-character-num-map.mjs && node scripts/generate-character-asset-map.mjs",
    "assets:generate-cobalt-infusion-catalog": "node scripts/generate-cobalt-infusion-catalog.mjs",
    "assets:report-cobalt-infusion-observations": "node backend/scripts/dev-smoke/report-cobalt-infusion-observations.mjs",
    "start:all": "node scripts/start-all.js",
    "stop:all": "node scripts/stop-all.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.10",
    "shadcn": "^4.3.0",
    "sharp": "^0.35.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
